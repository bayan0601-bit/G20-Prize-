<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G20 K-Research Innovation Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans KR',sans-serif;background:#F4F6FA;color:#1a1a2e;font-size:15px;}

/* ── GNB ── */
.gnb{background:#0B2050;color:#fff;padding:0 48px;display:flex;align-items:center;justify-content:space-between;height:62px;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(0,0,0,0.3);}
.gnb-logo{display:flex;align-items:center;gap:12px;text-decoration:none;flex-shrink:0;}
.gnb-badge{background:#1A73C8;color:#fff;font-size:11px;padding:3px 10px;border-radius:4px;font-weight:700;letter-spacing:1px;}
.gnb-title{color:#fff;font-size:15px;font-weight:700;letter-spacing:-0.3px;}
.gnb-nav{display:flex;align-items:center;gap:2px;list-style:none;height:62px;}
.gnb-item{position:relative;height:62px;display:flex;align-items:center;}
.gnb-item>a{color:rgba(255,255,255,0.85);text-decoration:none;font-size:13px;padding:0 16px;height:62px;display:flex;align-items:center;gap:4px;transition:all 0.2s;white-space:nowrap;}
.gnb-item>a:hover,.gnb-item:hover>a{color:#fff;background:rgba(255,255,255,0.08);}
.gnb-item>a.active{color:#5BB8F5;}
.gnb-item>a .arrow{font-size:10px;transition:transform 0.2s;opacity:0.6;}
.gnb-item:hover>a .arrow{transform:rotate(180deg);}

/* 드롭다운 */
.dropdown{position:absolute;top:62px;left:0;background:#fff;border:1px solid #E0E7F0;border-radius:0 0 10px 10px;min-width:170px;box-shadow:0 8px 24px rgba(11,32,80,0.15);opacity:0;visibility:hidden;transform:translateY(-6px);transition:all 0.2s;z-index:300;}
.gnb-item:hover .dropdown{opacity:1;visibility:visible;transform:translateY(0);}
.dropdown a{display:flex;align-items:center;gap:8px;padding:11px 18px;font-size:13px;color:#1a1a2e;text-decoration:none;transition:background 0.15s;border-bottom:1px solid #F0F4F8;}
.dropdown a:last-child{border-bottom:none;border-radius:0 0 10px 10px;}
.dropdown a:hover{background:#F0F7FF;color:#1A73C8;}
.dropdown a i{font-size:15px;color:#1A73C8;}

.gnb-right{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.btn-mypage{background:transparent;border:none;color:rgba(255,255,255,0.75);font-size:13px;padding:7px 12px;border-radius:6px;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all 0.2s;}
.btn-mypage:hover{color:#fff;background:rgba(255,255,255,0.08);}
.btn-mypage i{font-size:17px;}
.gnb-divider{width:1px;height:20px;background:rgba(255,255,255,0.2);}
.btn-login{background:transparent;border:1px solid rgba(255,255,255,0.35);color:#fff;font-size:13px;padding:7px 18px;border-radius:6px;cursor:pointer;transition:all 0.2s;}
.btn-login:hover{background:rgba(255,255,255,0.1);}
.btn-join{background:#1A73C8;border:none;color:#fff;font-size:13px;padding:7px 18px;border-radius:6px;cursor:pointer;font-weight:500;transition:background 0.2s;}
.btn-join:hover{background:#1558A8;}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,#0B2050 0%,#163880 55%,#1A73C8 100%);color:#fff;padding:60px 48px 52px;overflow:hidden;position:relative;}
.hero::before{content:'';position:absolute;right:-80px;top:-80px;width:480px;height:480px;border:1px solid rgba(255,255,255,0.05);border-radius:50%;}
.hero::after{content:'';position:absolute;right:-30px;top:-30px;width:320px;height:320px;border:1px solid rgba(255,255,255,0.05);border-radius:50%;}
.hero-inner{max-width:1060px;margin:0 auto;display:grid;grid-template-columns:1fr 360px;gap:48px;align-items:center;}
.hero h1{font-size:30px;font-weight:700;line-height:1.45;margin-bottom:14px;letter-spacing:-0.5px;}
.hero h1 em{color:#5BB8F5;font-style:normal;}
.hero-desc{font-size:14px;color:rgba(255,255,255,0.72);line-height:1.8;margin-bottom:28px;}
.hero-btns{display:flex;gap:12px;}
.hero-btn-p{background:#1A73C8;color:#fff;border:none;padding:12px 24px;border-radius:8px;font-size:14px;cursor:pointer;font-weight:700;transition:background 0.2s;}
.hero-btn-p:hover{background:#1558A8;}
.hero-btn-o{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.45);padding:12px 24px;border-radius:8px;font-size:14px;cursor:pointer;transition:all 0.2s;}
.hero-btn-o:hover{background:rgba(255,255,255,0.08);}

/* 히어로 우측 카드 */
.hero-card{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:16px;padding:24px;backdrop-filter:blur(4px);}
.hero-card-label{font-size:11px;color:rgba(255,255,255,0.45);margin-bottom:14px;letter-spacing:0.6px;text-transform:uppercase;}
.stat-row{display:flex;}
.stat-box{flex:1;text-align:center;padding:14px 6px;border-right:1px solid rgba(255,255,255,0.1);}
.stat-box:last-child{border-right:none;}
.stat-num{font-size:22px;font-weight:700;color:#5BB8F5;}
.stat-lbl{font-size:10px;color:rgba(255,255,255,0.5);margin-top:3px;}
.hcard-div{border:none;border-top:1px solid rgba(255,255,255,0.1);margin:14px 0;}
.field-tags{display:flex;flex-wrap:wrap;gap:6px;}
.ftag{background:rgba(255,255,255,0.09);color:rgba(255,255,255,0.78);font-size:11px;padding:4px 10px;border-radius:20px;border:1px solid rgba(255,255,255,0.13);}

/* ── 검색 탭 ── */
.search-section{background:#fff;border-bottom:2px solid #E0E7F0;padding:0 48px;}
.search-inner{max-width:1060px;margin:0 auto;}
.search-tabs{display:flex;gap:0;}
.stab{padding:18px 28px;font-size:14px;font-weight:500;color:#888;cursor:pointer;border-bottom:3px solid transparent;transition:all 0.2s;display:flex;align-items:center;gap:8px;}
.stab:hover{color:#1A73C8;}
.stab.active{color:#1A73C8;border-bottom-color:#1A73C8;font-weight:700;}
.stab i{font-size:17px;}
.search-panel{display:none;padding:24px 0 28px;}
.search-panel.active{display:block;}
.search-row{display:flex;gap:12px;align-items:center;}
.search-input{flex:1;border:1.5px solid #D0D7E3;border-radius:8px;padding:11px 16px;font-size:14px;font-family:inherit;outline:none;transition:border 0.2s;}
.search-input:focus{border-color:#1A73C8;}
.search-select{border:1.5px solid #D0D7E3;border-radius:8px;padding:11px 14px;font-size:13px;font-family:inherit;outline:none;color:#444;min-width:130px;background:#fff;}
.search-btn{background:#1A73C8;color:#fff;border:none;padding:11px 24px;border-radius:8px;font-size:14px;cursor:pointer;font-weight:700;white-space:nowrap;display:flex;align-items:center;gap:6px;transition:background 0.2s;}
.search-btn:hover{background:#1558A8;}
.search-tags{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;align-items:center;}
.search-tag-label{font-size:12px;color:#888;}
.qtag{background:#EBF4FF;color:#1A73C8;font-size:12px;padding:4px 12px;border-radius:20px;cursor:pointer;border:1px solid #C5DEFF;transition:all 0.15s;}
.qtag:hover{background:#1A73C8;color:#fff;}
.search-results{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:20px;}
.sr-card{border:1px solid #E0E7F0;border-radius:10px;padding:14px;background:#FAFBFD;cursor:pointer;transition:all 0.2s;}
.sr-card:hover{border-color:#1A73C8;background:#F0F7FF;}
.sr-avatar{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;margin-bottom:10px;}
.av-b{background:#DDEEFF;color:#0C447C;}.av-g{background:#D5F0E0;color:#1B8A52;}.av-a{background:#FDEDC7;color:#7A4500;}.av-p{background:#EDE8FF;color:#4A2E8A;}
.sr-name{font-size:13px;font-weight:700;color:#0B2050;margin-bottom:2px;}
.sr-affil{font-size:11px;color:#888;margin-bottom:8px;}
.sr-field{display:inline-block;font-size:10px;padding:3px 9px;border-radius:20px;background:#EBF4FF;color:#1A73C8;}
.task-results{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:20px;}
.tr-card{border:1px solid #E0E7F0;border-radius:10px;padding:16px;background:#FAFBFD;cursor:pointer;transition:all 0.2s;}
.tr-card:hover{border-color:#1A73C8;box-shadow:0 4px 12px rgba(26,115,200,0.1);}
.tr-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.tr-icon{font-size:22px;}
.tr-card h4{font-size:13px;font-weight:700;color:#0B2050;margin-bottom:6px;line-height:1.4;}
.tr-meta{display:flex;gap:8px;font-size:11px;color:#888;flex-wrap:wrap;}
.tr-nation{color:#1A73C8;font-weight:500;}

/* ── MAIN ── */
.main-bg{background:#F4F6FA;padding:40px 0;}
.main-wrap{max-width:1060px;margin:0 auto;padding:0 48px;}
.sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.sec-hd h2{font-size:16px;font-weight:700;color:#0B2050;display:flex;align-items:center;gap:8px;}
.sec-hd h2 i{color:#1A73C8;font-size:19px;}
.sec-link{font-size:13px;color:#1A73C8;text-decoration:none;font-weight:500;}
.sec-link:hover{text-decoration:underline;}

/* ── 신청 단계 프로세스 ── */
.process-box{background:#fff;border:1px solid #E0E7F0;border-radius:14px;padding:26px 28px;margin-bottom:40px;}
.process-box h2{font-size:15px;font-weight:700;color:#0B2050;margin-bottom:22px;display:flex;align-items:center;gap:8px;}
.process-box h2 i{color:#1A73C8;}
.proc-steps{display:flex;align-items:flex-start;position:relative;}
.proc-steps::before{content:'';position:absolute;top:20px;left:28px;right:28px;height:2px;background:linear-gradient(90deg,#1A73C8 37%,#E0E7F0 37%);z-index:0;}
.proc-step{flex:1;text-align:center;position:relative;z-index:1;}
.proc-num{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;margin:0 auto 8px;border:2px solid #E0E7F0;background:#fff;}
.proc-num.done{background:#1A73C8;color:#fff;border-color:#1A73C8;}
.proc-num.now{background:#fff;color:#1A73C8;border-color:#1A73C8;box-shadow:0 0 0 3px rgba(26,115,200,0.15);}
.proc-num.up{color:#bbb;border-color:#E0E7F0;}
.proc-label{font-size:11px;font-weight:700;color:#0B2050;margin-bottom:2px;line-height:1.3;}
.proc-pct{font-size:10px;font-weight:700;color:#1A73C8;}
.proc-pct.gray{color:#bbb;}
/* 프로세스 화살표 */
.proc-arrow{display:flex;align-items:center;padding-top:10px;color:#D0D7E3;font-size:14px;}
.proc-arrow.done-arr{color:#1A73C8;}

/* ── 도전과제 카드 ── */
.cg{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:40px;}
.cc{background:#fff;border:1px solid #E0E7F0;border-radius:14px;padding:22px;cursor:pointer;transition:all 0.2s;}
.cc:hover{box-shadow:0 8px 24px rgba(11,32,80,0.11);transform:translateY(-2px);}
.cc-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
.cicon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.ci-q{background:#EBF4FF;}.ci-b{background:#EDFAF3;}.ci-a{background:#FFF8EC;}.ci-c{background:#F0FBF5;}
.tag{display:inline-flex;align-items:center;gap:3px;font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;}
.t-open{background:#EBF4FF;color:#1A73C8;}.t-hot{background:#FFF0EC;color:#D84315;}.t-new{background:#EDFAF3;color:#1B8A52;}
.cc h3{font-size:13px;font-weight:700;color:#0B2050;margin-bottom:7px;line-height:1.5;}
.cc p{font-size:12px;color:#666;line-height:1.6;margin-bottom:14px;}

/* 단계 프로세스 (카드 내부) */
.card-proc{margin-bottom:14px;}
.card-proc-label{font-size:11px;color:#888;margin-bottom:6px;}
.card-proc-steps{display:flex;align-items:center;gap:3px;flex-wrap:wrap;}
.cps{font-size:10px;padding:3px 7px;border-radius:4px;font-weight:500;white-space:nowrap;}
.cps.done{background:#1A73C8;color:#fff;}
.cps.now{background:#EBF4FF;color:#1A73C8;border:1px solid #1A73C8;}
.cps.up{background:#F4F6FA;color:#aaa;}
.cps-arr{color:#ccc;font-size:9px;}

.cc-bot{display:flex;align-items:center;justify-content:space-between;border-top:1px solid #F0F4F8;padding-top:12px;}
.cdl{font-size:12px;color:#888;}
.cdl strong{color:#E24B4A;}
.cnat{font-size:12px;color:#1A73C8;font-weight:500;}

/* ── 2col ── */
.two-col{display:grid;grid-template-columns:1fr 330px;gap:22px;margin-bottom:40px;}
.qcard{background:#fff;border:1px solid #E0E7F0;border-radius:14px;padding:20px;}
.qcard h2{font-size:15px;font-weight:700;color:#0B2050;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.qcard h2 i{color:#1A73C8;}
.qg{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.qi{border:1px solid #E0E7F0;border-radius:10px;padding:15px 10px;text-align:center;cursor:pointer;transition:all 0.2s;}
.qi:hover{border-color:#1A73C8;background:#F0F7FF;}
.qi-ic{font-size:24px;color:#1A73C8;margin-bottom:7px;}
.qi strong{display:block;font-size:12px;font-weight:700;color:#0B2050;margin-bottom:3px;}
.qi p{font-size:10px;color:#888;line-height:1.4;}

/* 공지 */
.ncard{background:#fff;border:1px solid #E0E7F0;border-radius:14px;padding:20px;}
.ncard h2{font-size:15px;font-weight:700;color:#0B2050;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.ncard h2 i{color:#1A73C8;}
.nlist{display:flex;flex-direction:column;gap:10px;}
.ni{display:flex;gap:12px;padding:11px;border:1px solid #F0F4F8;border-radius:10px;cursor:pointer;transition:background 0.15s;}
.ni:hover{background:#F7FAFF;}
.ndate{min-width:40px;text-align:center;}
.nmon{font-size:9px;color:#888;background:#F4F6FA;padding:2px 5px;border-radius:3px;display:block;margin-bottom:3px;}
.nday{font-size:19px;font-weight:700;color:#1A73C8;line-height:1;}
.nbody h4{font-size:12px;font-weight:700;color:#0B2050;margin-bottom:3px;line-height:1.4;}
.nbody p{font-size:11px;color:#888;line-height:1.5;}
.ntag{display:inline-block;font-size:10px;padding:2px 7px;border-radius:4px;margin-bottom:4px;font-weight:600;}
.nt-a{background:#EBF4FF;color:#1A73C8;}.nt-e{background:#FFF8EC;color:#854F0B;}.nt-r{background:#EDFAF3;color:#1B8A52;}

/* ── 협력 우수 연구자 ── */
.rg{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:40px;}
.rc{background:#fff;border:1px solid #E0E7F0;border-radius:14px;padding:18px;text-align:center;cursor:pointer;transition:all 0.2s;position:relative;}
.rc:hover{box-shadow:0 6px 18px rgba(11,32,80,0.1);transform:translateY(-2px);}
.rc-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#1A73C8;color:#fff;font-size:9px;font-weight:700;padding:3px 10px;border-radius:0 0 8px 8px;white-space:nowrap;letter-spacing:0.3px;}
.av{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;margin:18px auto 10px;}
.avb{background:#DDEEFF;color:#0C447C;}.avg{background:#D5F0E0;color:#1B8A52;}.ava{background:#FDEDC7;color:#7A4500;}.avp{background:#EDE8FF;color:#4A2E8A;}
.rname{font-size:13px;font-weight:700;color:#0B2050;margin-bottom:2px;}
.raffil{font-size:10px;color:#888;margin-bottom:8px;line-height:1.4;}
.rfld{display:inline-block;font-size:10px;padding:3px 9px;border-radius:20px;background:#EBF4FF;color:#1A73C8;}
.r-match{font-size:10px;color:#1B8A52;font-weight:600;margin-top:6px;display:flex;align-items:center;justify-content:center;gap:3px;}

/* FOOTER */
footer{background:#0B2050;color:rgba(255,255,255,0.6);padding:36px 48px 28px;}
.foot-in{max-width:1060px;margin:0 auto;}
.foot-top{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;margin-bottom:24px;}
.foot-logo{color:#fff;font-size:15px;font-weight:700;margin-bottom:8px;}
.foot-desc{font-size:12px;line-height:1.7;color:rgba(255,255,255,0.45);}
.foot-ct{font-size:11px;font-weight:700;color:rgba(255,255,255,0.65);margin-bottom:10px;letter-spacing:0.4px;text-transform:uppercase;}
.foot-links{list-style:none;display:flex;flex-direction:column;gap:6px;}
.foot-links a{color:rgba(255,255,255,0.45);text-decoration:none;font-size:12px;transition:color 0.2s;}
.foot-links a:hover{color:#5BB8F5;}
.foot-bot{border-top:1px solid rgba(255,255,255,0.1);padding-top:18px;display:flex;align-items:center;justify-content:space-between;}
.foot-copy{font-size:11px;color:rgba(255,255,255,0.28);}
.foot-orgs{display:flex;gap:10px;}
.foot-org{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.45);font-size:11px;padding:4px 10px;border-radius:4px;}
</style>
</head>
<body>

<!-- ── GNB ── -->
<nav class="gnb">
  <a class="gnb-logo" href="#">
    <span class="gnb-badge">G20</span>
    <span class="gnb-title">K-Research Innovation</span>
  </a>
  <ul class="gnb-nav">

    <!-- 사업소개 -->
    <li class="gnb-item">
      <a href="#">사업소개 <i class="ti ti-chevron-down arrow"></i></a>
      <div class="dropdown">
        <a href="#"><i class="ti ti-file-description"></i>사업개요</a>
        <a href="#"><i class="ti ti-sitemap"></i>사업추진체계</a>
      </div>
    </li>

    <!-- 과제공고 -->
    <li class="gnb-item">
      <a href="#">과제공고 <i class="ti ti-chevron-down arrow"></i></a>
      <div class="dropdown">
        <a href="#"><i class="ti ti-list"></i>공고 목록</a>
        <a href="#"><i class="ti ti-trophy"></i>분야별 과제 목록</a>
      </div>
    </li>

    <!-- 연구자·과제 검색 -->
    <li class="gnb-item">
      <a href="#">연구자·과제 검색 <i class="ti ti-chevron-down arrow"></i></a>
      <div class="dropdown">
        <a href="#"><i class="ti ti-user-search"></i>연구자 검색</a>
        <a href="#"><i class="ti ti-search"></i>과제 검색</a>
        <a href="#"><i class="ti ti-users"></i>협력 매칭</a>
      </div>
    </li>

    <!-- 네트워킹 -->
    <li class="gnb-item">
      <a href="#">네트워킹 <i class="ti ti-chevron-down arrow"></i></a>
      <div class="dropdown">
        <a href="#"><i class="ti ti-messages"></i>협력 게시판</a>
        <a href="#"><i class="ti ti-users-group"></i>워킹그룹 현황</a>
      </div>
    </li>

    <!-- 알림마당 -->
    <li class="gnb-item">
      <a href="#">알림마당 <i class="ti ti-chevron-down arrow"></i></a>
      <div class="dropdown">
        <a href="#"><i class="ti ti-bell"></i>공지사항</a>
        <a href="#"><i class="ti ti-file-text"></i>규정 및 양식</a>
        <a href="#"><i class="ti ti-chart-bar"></i>통계자료</a>
        <a href="#"><i class="ti ti-help-circle"></i>자주 묻는 질문</a>
      </div>
    </li>

  </ul>
  <div class="gnb-right">
    <button class="btn-mypage"><i class="ti ti-user-circle"></i>마이페이지</button>
    <span class="gnb-divider"></span>
    <button class="btn-login">로그인</button>
    <button class="btn-join">회원가입</button>
  </div>
</nav>

<!-- ── HERO ── -->
<section class="hero">
